{
  "budget": {
    "max_bytes": 8000
  },
  "build_profile": "browser-kernel",
  "manifest_version": 1,
  "outputs": [
    {
      "kind": "single_source_markdown",
      "path": "builds/rendered/browser/Lares_Kernel.browser.md"
    }
  ],
  "package_id": "browser-kernel",
  "renderer_version": "0.2.0",
  "sources": [
    {
      "module_id": "lares-kernel",
      "transform": {
        "type": "full"
      }
    }
  ],
  "target_class": "browser-safe",
  "target_platform": "browser",
  "verification": {
    "emit_checksums": true,
    "emit_lockfile": true,
    "emit_report": true
  }
}
