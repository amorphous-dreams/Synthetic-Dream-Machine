{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "baseUrl": ".",
    "paths": {
      "@lararium/mesh": ["packages/lararium-mesh/src/index.ts"],
      "@lararium/mesh/*": [
        "packages/lararium-mesh/*",
        "packages/lararium-mesh/src/*"
      ],
      "@lararium/types": ["packages/lararium-types/src/index.ts"],
      "@lararium/types/*": [
        "packages/lararium-types/*",
        "packages/lararium-types/src/*"
      ],
      "@lararium/tw5": ["packages/lararium-tw5/src/index.ts"],
      "@lararium/tw5/*": [
        "packages/lararium-tw5/*",
        "packages/lararium-tw5/src/*"
      ]
    },
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "isolatedModules": true
  }
}
