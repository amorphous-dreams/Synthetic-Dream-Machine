{
  "name": "@lararium/node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lararium": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules pnpm exec jest --config jest.config.cjs",
    "dev": "tsx src/index.ts",
    "build-snapshot": "tsx scripts/build-snapshot.ts",
    "serve": "tsx scripts/serve.ts",
    "e2e": "playwright test --config playwright.config.ts",
    "e2e:headed": "playwright test --config playwright.config.ts --headed"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.6",
    "@automerge/automerge-repo": "^2.5.5",
    "@automerge/automerge-repo-network-websocket": "^2.5.5",
    "@automerge/automerge-repo-storage-nodefs": "^2.5.5",
    "@lararium/core": "workspace:*",
    "@lararium/tldraw": "workspace:*",
    "@lararium/tw5": "workspace:*",
    "@tldraw/sync-core": "^4.5.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/ws": "^8.18.1",
    "better-sqlite3": "^12.9.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@playwright/test": "^1.59.1",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0"
  }
}
