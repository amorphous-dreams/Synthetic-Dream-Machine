{
  "name": "@lararium/node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build":          "tsc",
    "typecheck":      "tsc --noEmit",
    "test":           "NODE_OPTIONS=--experimental-vm-modules pnpm exec jest --config jest.config.cjs",
    "dev":            "tsx src/main.ts",
    "start":          "node dist/src/main.js"
  },
  "dependencies": {
    "@automerge/automerge": "^3.2.6",
    "@automerge/automerge-repo": "^2.5.5",
    "@automerge/automerge-repo-network-websocket": "^2.5.5",
    "@automerge/automerge-repo-storage-nodefs": "^2.5.5",
    "@lararium/core": "workspace:*",
    "@lares/lares": "workspace:*",
    "@lararium/tw5": "workspace:*",
    "@octokit/rest": "^22.0.1",
    "@types/ws": "^8.18.1",
    "isomorphic-ws": "^5.0.0",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.0",
    "tsx": "^4.19.0"
  }
}
