{
  "name": "@lararium/node",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "lararium": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "NODE_OPTIONS=--experimental-vm-modules pnpm exec jest --config jest.config.cjs",
    "dev": "tsx src/index.ts",
    "build-snapshot": "tsx scripts/build-snapshot.ts",
    "serve": "tsx src/serve.ts"
  },
  "dependencies": {
    "@lararium/core": "workspace:*",
    "@lararium/tldraw": "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.0",
    "jest": "^29.7.0",
    "@jest/globals": "^29.7.0",
    "ts-jest": "^29.2.0"
  }
}
