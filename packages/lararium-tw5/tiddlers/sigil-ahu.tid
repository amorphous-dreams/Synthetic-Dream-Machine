title: lar:///ha.ka.ba/@lararium/tw5/tiddlers/sigil-ahu
tags: $:/tags/Global lar:///ha.ka.ba/tags/SharktoothSigil
lar-kind: child-slot
lar-pono-uri: lar:///ha.ka.ba/@lares/api/v0.1/pono/ahu
lar-open-pattern: <<~[^>]*\bahu\s+(#[\w-]+)\s*>>
lar-close-pattern: <<~\/ahu\s*>>
type: text/vnd.tiddlywiki

<!-- ahu — worksite scope boundary; addressable child-slot tiddler at parentUri+slot.

     ~kahea~ahu → AhuTemplate cascade (live child-slot transclusion).
     ~aka~ahu   → AkaTemplate cascade (frozen/projection read of child slot).
     Render posture lives in the template cascade, not in the sigil procedure.

     Live wiki parent tiddlers hold <<~ kahea ahu #slot >> (space form, HUD-readable).
     lar-sigil.ts routes compound forms: name="kahea~ahu", p1=slot. -->

\widget ~ahu(slot:"" uri:"" p1:"")
<$let _ahu-slot={{{ [<slot>!match[]] ~[<p1>] }}}>
<$let _ahu-uri={{{ [<uri>!match[]!regexp[^lar:///unknown]] ~[<_ahu-slot>regexp[^lar:]] ~[<currentTiddler>addsuffix<_ahu-slot>] }}}
      _ahu-template={{{ [all[shadows+tiddlers]tag[lar:///ha.ka.ba/tags/ahu-template]!is[draft]] :map:flat[subfilter{!!text}] +[first[]else[lar:///ha.ka.ba/@lararium/templates/ahu/html]] }}}>
<$tiddler tiddler=<<_ahu-uri>>>
<$transclude $tiddler=<<_ahu-template>>/>
</$tiddler>
</$let>
</$let>
\end

\procedure ~kahea~ahu(slot:"" uri:"" p1:"")
<$transclude $variable="~ahu" slot=<<slot>> uri=<<uri>> p1=<<p1>>/>
\end

\procedure ~aka~ahu(slot:"" uri:"" p1:"")
<$let _a-slot={{{ [<slot>!match[]] ~[<p1>] }}}>
<$let _a-uri={{{ [<uri>!match[]!regexp[^lar:///unknown]] ~[<_a-slot>regexp[^lar:]] ~[<currentTiddler>addsuffix<_a-slot>] }}}
      _a-template={{{ [all[shadows+tiddlers]tag[lar:///ha.ka.ba/tags/aka-template]!is[draft]] :map:flat[subfilter{!!text}] +[first[]else[lar:///ha.ka.ba/@lararium/templates/aka/html]] }}}>
<$tiddler tiddler=<<_a-uri>>>
<$transclude $tiddler=<<_a-template>>/>
</$tiddler>
</$let>
</$let>
\end
