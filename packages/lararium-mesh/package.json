{
  "name": "@lararium/mesh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./cascade": {
      "import": "./dist/cascade.js",
      "types": "./dist/cascade.d.ts"
    },
    "./lar-uris": {
      "import": "./dist/lar-uris.js",
      "types": "./dist/lar-uris.d.ts"
    },
    "./mirror-paths": {
      "import": "./dist/mirror-paths.js",
      "types": "./dist/mirror-paths.d.ts"
    },
    "./promotion-ceremony": {
      "import": "./dist/promotion-ceremony.js",
      "types": "./dist/promotion-ceremony.d.ts"
    },
    "./live-protocol": {
      "import": "./dist/live-protocol.js",
      "types": "./dist/live-protocol.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "prebuild": "node ../../tools/clean-output.mjs dist",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "dev": "tsx src/index.ts"
  },
  "devDependencies": {
    "tiddlywiki": "^5.4.0",
    "vitest": "^3.2.0",
    "tsx": "^4.19.0"
  },
  "dependencies": {
    "@automerge/automerge-repo": "^2.5.5",
    "@noble/ed25519": "^3.1.0",
    "@noble/hashes": "^2.2.0"
  }
}
