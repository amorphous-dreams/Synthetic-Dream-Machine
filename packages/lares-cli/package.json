{
  "name": "@lares/cli",
  "version": "0.1.0",
  "private": true,
  "description": "Lares operator CLI — lares init, lares promote, lares heleuma, … One entry point for every operator-facing ceremony.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "bin": {
    "lares": "./dist/src/bin/lares.js"
  },
  "scripts": {
    "build":     "tsc",
    "dev":       "tsx src/bin/lares.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lararium/core": "workspace:*",
    "@lararium/node": "workspace:*",
    "@lararium/tw5":  "workspace:*"
  },
  "devDependencies": {
    "tsx": "^4.19.0"
  }
}
