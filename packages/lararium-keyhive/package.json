{
  "name": "@lararium/keyhive",
  "version": "0.1.0",
  "private": true,
  "description": "Keyhive (Ink & Switch concap) integration for the Lares stack — capability layer + probes against pre-alpha @keyhive/keyhive WASM bindings.",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "prebuild": "node ../../tools/clean-output.mjs dist",
    "build":     "tsc",
    "typecheck": "tsc --noEmit -p tsconfig.typecheck.json"
  },
  "dependencies": {
    "@keyhive/keyhive": "0.0.0-alpha.56c",
    "@lararium/mesh":  "workspace:*"
  }
}
