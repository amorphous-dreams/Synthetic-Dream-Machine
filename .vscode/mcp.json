{
  "servers": {
    "lararium": {
      "type": "stdio",
      "command": "node",
      "args": ["packages/lararium-mcp/dist/stdio.js"],
      "cwd": ".",
      "env": {}
    },
    "lararium-python": {
      "type": "stdio",
      "command": ".venv/bin/python3",
      "args": ["-m", "lares.lararium_mcp"],
      "cwd": ".",
      "env": {}
    }
  }
}
