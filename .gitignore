# Local environments / dependency installs
.venv/
.bundle/
vendor/

# Generated site/build output
_site/
_becmi/
_todo/_page_renders/.cache/

node_modules/

# Generated media / archives
**/hires_*
*.zip

# Python bytecode / caches
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Python packaging/build artifacts
*.egg-info/
build/
dist/
# lararium-node generated artifacts
lares/lararium-node/snapshot.json
lares/lararium-node/fixtures.current.json

# pnpm/Node
node_modules/
packages/*/dist/
packages/*/dist-bundle/
packages/*/node_modules/
.lararium-data/

# Generated source files (rebuilt by build scripts)
packages/lararium-tw5/src/generated-ui-preloads.ts

# Playwright CLI + test artifacts
.playwright-cli/
packages/lararium-app/test-results
packages/lararium-node/test-results
packages/lararium-node/playwright-report
**/playwright-report/
**/test-results/**/tests/.playwright-userdata/

# Lararium node storage — per-deployment, never committed
.lararium
packages/lararium-node/.lararium/
packages/lararium-tw5/public/tiddlywikicore-*.js

# Room-bag disk scratch — operator's editable surface, never committed.
# Promotion ceremony moves files from rooms/{slug}/ into packages/.
rooms/

# Per-deployment social bootstrap (operator AutomergeUrls) — written by
# `lararium:init`, consumed at boot. Never committed.
packages/lararium-node/genesis/social-bootstrap.json
